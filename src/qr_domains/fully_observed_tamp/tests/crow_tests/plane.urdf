<?xml version="1.0" ?>
<robot name="plane">
  <link name="planeLink">
    <contact>
      <lateral_friction value="1"/>
    </contact>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value=".0"/>
      <inertia ixx="0" ixy="0" ixz="0" iyy="0" iyz="0" izz="0"/>
    </inertial>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 -0.06"/>
      <geometry>
        <box size="2 2 0.1"/>
      </geometry>
    </collision>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 -0.06"/>
      <geometry>
        <box size="2 2 0.1"/>
      </geometry>
      <material name="LightGrey">
        <color rgba="0.9 0.9 0.9 1"/>
      </material>
    </visual>
  </link>
</robot>

